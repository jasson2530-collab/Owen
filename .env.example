# ════════════════════════════════════════
# 資料庫設定
# ════════════════════════════════════════

# 本地開發：使用 SQLite（自動建立 reminders.db 檔案）
DATABASE_URL=sqlite:///./reminders.db

# 雲端部署：使用 PostgreSQL（Render 會自動注入這個環境變數）
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ════════════════════════════════════════
# 應用程式設定
# ════════════════════════════════════════

# 時區（不要修改）
TIMEZONE=Asia/Taipei

# 伺服器 Port（Render/Railway 會自動設定，本地測試用 8000）
PORT=8000
